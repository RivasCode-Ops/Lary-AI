# LARY AI — Environment Variables
# Copy this to .env and fill in your values.
# Para Railway: setar estas variáveis no dashboard (Project > Variables).

# Database (Railway: usar DATABASE_URL do plugin PostgreSQL)
DATABASE_URL=postgresql://lary:lary123@localhost:5433/laryai

# OpenAI (obrigatório para IA extraction)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Redis (opcional, usado para filas)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# Supabase Storage (opcional, usado para fotos)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
STORAGE_BUCKET=laryai-fotos

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
